<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MoneyTrack" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/blue_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/violet_700</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/slate_100</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/slate_800</item>
        <item name="android:statusBarColor" tools:targetApi="l">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    </style>

    <style name="CashFlowChartStyle">
        <item name="layers">column</item>
        <item name="showBottomAxis">true</item>
        <item name="showStartAxis">true</item>
    </style>

    <style name="PatrimonyChartStyle">
        <item name="layers">column</item>
        <item name="showBottomAxis">true</item>
        <item name="showStartAxis">true</item>
    </style>
</resources>
